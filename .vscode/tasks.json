{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Debug",
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#22d63a"
                }
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmake --build --preset Debug --target clean",
            "problemMatcher": [],
            "group": "build",
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#e91f11"
                }
            }
        },
        {
            "label": "Clean & Rebuild",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Debug --clean-first",
            "problemMatcher": "$gcc",
            "group": "build",
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#e9e507"
                }
            }
        },
        {
            "label": "BuildSize",
            "type": "shell",
            "command": "arm-none-eabi-size",
            "args": ["./build/Debug/F767_i2c.elf"],
            "group": "build",
            "dependsOn": ["Build"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            },
            "options": {
                "statusbar": {
                    "color": "#0cec2a",
                    "filePattern": ""
                }
            }
        },
        {
            "label": "OpenConfiguration",
            "type": "shell",
            "command": "stm32cubemx",
            "args": ["./F767_i2c.ioc"],
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            },
            "options": {
                "statusbar": {
                    "color": "#13e6e6",
                    "filePattern": "",
                    "icon": {
                        "id": "gear"
                    }
                }
            }
        },
        {
            "label": "Flash STM32",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg",
                "-f", "target/stm32f7x.cfg",
                "-c", "program build/Debug/F767_i2c.elf verify reset exit"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": ["Clean & Rebuild", "BuildSize"],
            "dependsOrder": "sequence",
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#13e6e6",
                    "detail": "Clean rebuild, show size, flash and reset",
                    "icon": {
                        "id": "play"
                    }
                }
            }
        },
        {
            "label": "Reset",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg",
                "-f", "target/stm32f7x.cfg",
                "-c", "init; reset run; exit"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#13e6e6",
                    "detail": "Reset the MCU",
                    "icon": {
                        "id": "refresh"
                    }
                }
            }
        },
        {
            "label": "Erase & Flash STM32",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg",
                "-f", "target/stm32f7x.cfg",
                "-c", "program build/Debug/F767_i2c.elf verify reset exit"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "dependsOn": ["Full CHIP Erase", "Build", "BuildSize"],
            "dependsOrder": "sequence",
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#d8e613",
                    "detail": "Erase, build, flash and reset",
                    "icon": {
                        "id": "gear"
                    }
                }
            }
        },
        {
            "label": "Full CHIP Erase",
            "type": "shell",
            "command": "st-flash",
            "args": ["erase"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#f53404",
                    "detail": "Erase the entire chip",
                    "icon": {
                        "id": "trash"
                    }
                }
            }
        },
        {
            "label": "Start Debug",
            "type": "shell",
            "command": "${command:workbench.action.debug.start}",
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#d67922",
                    "detail": "Start Debug",
                    "icon": {
                        "id": "debug-start"
                    }
                }
            }
        },
        {
            "label": "Serial Monitor (ST-Link VCP)",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/tools/serial_monitor.sh"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "options": {
                "statusbar": {
                    "hide": false,
                    "color": "#9b59b6",
                    "detail": "Open a live 115200-baud serial view of the ST-Link VCP (auto-detects the port)",
                    "icon": {
                        "id": "output"
                    }
                }
            }
        },
        {
            "label": "Post Debug Task",
            "type": "shell",
            "command": "echo 'Debug session ended.'",
            "problemMatcher": [],
            "presentation": {
                "clear": true
            },
            "options": {
                "statusbar": {
                    "hide": true
                }
            }
        }
    ]
}
